{
    "$schema": "http://json-schema.org/draft-07/schema#",	// JSON 표준 문법(규칙) 버전
    "title": "Narrative Logic Engine Master Schema (Template Edition)",
    
    "definitions": {
        /* 캐릭터 스키마: 작품에 등장하는 캐릭터를 데이터셋에 저장할 때 필수 내용과 형식을 정의 */
        "character_schema": {
            "type": "object",

            /* 모든 캐릭터에 꼭 작성되어야 하는 속성 */
            "required": [
            "char_id", 
            "name", 
            "char_role", 
            $ 아래 두 속성은 검증모듈 설계 내용에 따라 변경 가능
            "dominant_trait",     // 지배적인 특성 
            "forbidden_action"    // 금지된 행동 
            ],
            /* 각 속성에 대한 규칙 */
            "properties": {
            "char_id": {
                "type": "string",
                "pattern": "^CHAR_[A-Z0-9_]+$", // [형식 강제] 반드시 CHAR_ 로 시작하는 영문/숫자 조합
                "description": "캐릭터 고유 ID"
            },
            "name": { "type": "string" },
            
            // 캐릭터 역할 (Template 방식)
            "char_role": {
                "type": "string",
                "description": "서사 내 핵심 역할. (필수: 주인공, 적대자 / 기본: 조력자 등 / 기타)"
            },
                        
            // 체계적인 캐릭터 관계망 정의 (선택적이지만 구조화됨)
            "char_relationship": {
                "type": "array",
                "description": "타 캐릭터와의 관계 구조도 (필수는 아님)",
                "items": {
                "type": "object",
                "properties": {
                    "category": { "type": "string", "description": "카테고리 (예: 가족, 적대, 연인, 동료)" },
                    "relationship_title": { "type": "string", "description": "관계 형태 (예: 배신한 스승)" },
                    "target_char_id": { "type": "string", "description": "대상 캐릭터의 char_id" },
                    "emotions": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "대상에 대한 감정 상태 (예: ['증오', '두려움', '동경'])"
                    }
                },
                "required": ["category", "relationship_title", "target_char_id", "emotions"]
                }
            },
            
            // 4. 서사 검증(Validator)을 위한 필수 제약 속성들(이론의 꼬리표를 뗀 순수 데이터)
            $ 아래 5개의 속성은 검증모듈 설계 내용에 따라 변경 가능
            "dominant_trait": { "type": "string", "description": "캐릭터의 핵심 성향 (위반 검증용)" },
            "motivation": { "type": "string", "description": "행동의 근거 및 동기" },
            "trauma_id": { "type": "string", "description": "트라우마 사전 ID 참조 (선택 사항)" },
            "forbidden_action": { "type": "string", "description": "캐릭터 붕괴(L_CHAR_V)를 판정하는 행동 제약" },
            "initial_lack": { "type": "string", "description": "주인공의 경우 모험을 떠나는 결핍 사유" }
            }
        },
      
        /* 세계관 스키마: 작품의 세계관을 데이터셋에 저장할 때 필수 내용과 형식을 정의 */
        "worldview_schema": {
            "type": "object",
            "required": ["world_id", "genre", "features", "rules"],
            "properties": {
                "world_id": { 
                    "type": "string",
                    "pattern": "^WORLD_[A-Z0-9_]+$"
                },
                "genre": { "type": "string" },
                
                // 세계관 작성 시 설정할 수 있는 특징 (동적 확장 구조)
                "features": {
                    "type": "object",
                    "description": "세계관을 구성하는 특징들 (예: 기술 수준, 마법 체계, 신분 제도 등)",
                    "additionalProperties": { "type": "string" } // 어떤 key 값이든 유연하게 추가 가능
                },
                
                "constants": {
                    "type": "array",
                    "description": "서사 내내 불변하는 환경 변수",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string", "description": "변수명 (예: 중력, 하루의 길이)" },
                            "value": { "type": "string", "description": "값 (예: 지구의 2배, 48시간)" }
                        }
                    }
                },
                
                // 법칙을 직접 담는 것이 아닌, '규칙의 구조'를 템플릿화
                "rules": {
                    "type": "array",
                    "description": "물리적/사회적 규칙과 위반 조건의 매핑",
                    "items": {
                        "type": "object",
                        "required": ["rule_title", "forbidden_events"],
                        "properties": {
                            "rule_title": { "type": "string", "description": "규칙 이름 (예: 마법 사용의 대가)" },
                            "description": { "type": "string", "description": "상세 설명" },
                            "forbidden_events": {
                            "type": "array",
                            "items": { "type": "string" },
                            "description": "세계관 위반(L_WORLD_V)을 유발하는 구체적 사건 (예: 생명력 소모 없이 마법 사용)"
                            }
                        }
                    }
                }
            }
        },

        /* 플롯 스키마: 작품의 세계관을 데이터셋에 저장할 때 필수 내용과 형식을 정의 */
        "plot_schema": {
            "type": "object",
            "required": ["Plot_Metadata", "Plot_Nodes"],
            "properties": {
                "Plot_Metadata": {
                    "type": "object",
                    "description": "해당 스토리의 전체 메타데이터 및 서사 뼈대 정보",
                    "required": ["Story_ID", "Title", "Applied_Structure", "Main_Characters", "Validation_Status"],
                    "properties": {
                        "Story_ID": { 
                        "type": "string", 
                        "pattern": "^STORY_[0-9]{8}_[A-Z0-9]+$",
                        "description": "스토리 고유 식별자 (예: STORY_20260324_001)" 
                        },
                        "Title": { "type": "string", "description": "플롯의 제목" },
                        "Author": { "type": "string", "description": "저작권자 또는 유저명" },
                        "Created_At": { "type": "string", "format": "date-time" },
                        "Updated_At": { "type": "string", "format": "date-time" },
                        "Applied_Structure": { 
                        "type": "string", 
                        "enum": ["propp", "vogler", "custom"],
                        "description": "이 스토리가 기반으로 삼고 있는 서사 구조론 (예: 프롭, 보글러)" 
                        },
                        "Main_Characters": {
                            "type": "object",
                            "required": ["Protagonist_ID"],
                            "properties": {
                                "Protagonist_ID": { "type": "string", "description": "주동자(주인공)의 Character ID" },
                                "Antagonist_ID": { "type": "string", "description": "적대자의 Character ID (개념적 적대자 포함)" }
                            }
                        },
                        "Core_Deficiency": {
                            "type": "object",
                            "description": "이야기를 관통하는 핵심 결핍 (주인공의 동기)",
                            "properties": {
                                "Immediate_Lack": { "type": "string", "description": "즉자적 결핍 (표면적 문제, 예: 돈, 아이템)" },
                                "Fundamental_Lack": { "type": "string", "description": "대자적 결핍 (내면적 문제, 예: 애정, 인정, 사회의 불합리한 구조)" }
                            }
                        },
                        "Tags": {
                            "type": "object",
                            "properties": {
                                "Topics": { "type": "array", "items": { "type": "string" }, "description": "스토리의 주요 장르 및 소재" },
                                "Polarity": { "type": "string", "enum": ["Positive", "Negative", "Neutral"], "description": "스토리의 전반적인 극성/분위기" }
                            }
                        },
                        "Validation_Status": {
                            "type": "object",
                            "description": "스토리 검증기(Validator)를 통과한 결과값",
                            "required": ["Violation_Rate", "Is_Valid"],
                            "properties": {
                                "Violation_Rate": { "type": "string", "description": "플롯 홀 및 설정 위반율 (목표: 0%)" },
                                "Is_Valid": { "type": "boolean", "description": "최종 검증 통과 여부" }
                            }
                        }
                    }   
                },

                "Plot_Nodes": {
                    "type": "array",
                    "description": "실제 이야기가 전개되는 개별 사건(장면) 노드들의 배열",
                    "items": {
                        "type": "object",
                        "required": ["Node_ID", "Function_ID", "Content", "Causal_Links", "Validation_Data"],
                        "properties": {
                            "Node_ID": { 
                                "type": "string", 
                                "description": "이 스토리 내에서 해당 사건 노드를 식별하는 고유 ID (예: N_001)" 
                            },
                            // 🌟 [추가됨] Fractional Indexing 기반의 순서 정렬 값
                            "Sequence_Index": { 
                              "type": "number", 
                              "description": "노드가 서사에서 배치되는 물리적/시간적 순서(실수값). 기존 노드(예: 3과 4) 사이에 새 노드 삽입 시 전체 인덱스를 수정할 필요 없이 3.5를 부여하여 유연하게 순서를 관리함." 
                            },
                            "Function_ID": { 
                                "type": "string", 
                                "description": "plot_theory.json에 정의된 구조론의 기능 ID 매핑 (예: P01, P04)" 
                            },
                            "Content": { 
                                "type": "string", 
                                "description": "해당 노드에서 벌어지는 구체적인 사건과 서술 (LLM 생성 영역)" 
                            },
                            "Involved_Characters": { 
                                "type": "array", 
                                "items": { "type": "string" }, 
                                "description": "이 사건에 등장/관여하는 캐릭터 ID 목록" 
                            },
                            "Background_World_ID": { 
                                "type": "string", 
                                "description": "이 사건이 벌어지는 배경/공간 ID" 
                            },
                            // 🌟 [수정됨] 필수 항목에서 선택 항목으로 변경, '원거리 인과성(복선과 회수)'으로 재정의
                            "Causal_Links": {
                                "type": "object",
                                "description": "선택적 항목. 바로 앞뒤 노드가 아닌, 서사 전체를 가로지르는 '원거리 인과관계(복선/트리거)'를 명시할 때만 사용함.",
                                "properties": {
                                    "Causes": { 
                                        "type": "array", 
                                        "items": { "type": "string" }, 
                                        "description": "현재 노드의 사건이 벌어지기 위해 저 멀리 앞단에서 반드시 발생했어야 하는(영향을 준) 노드 ID 배열 (예: 1막에서 독약을 얻은 노드)"
                                    },
                                    "Effects": { 
                                        "type": "array", 
                                        "items": { "type": "string" }, 
                                        "description": "현재 노드의 사건이 훗날 멀리 떨어진 챕터에서 벌어질 특정 사건에 치명적 영향을 미칠 때(복선 투척), 그 대상 노드 ID 배열" 
                                    }
                                }
                            },

                            $ 아래 Validation_Date은 검증모듈 설계 내용에 따라 변경 가능 
                            "Validation_Data": {
                                "type": "object",
                                "description": "해당 사건이 캐릭터/세계관 설정을 위반하지 않는지 검사하기 위한 제약 조건 데이터",
                                "required": ["Effect_Type"],
                                "properties": {
                                    "Required_Trait": { 
                                        "type": "string", 
                                        "description": "이 행동을 하기 위해 캐릭터가 필수로 가져야 하는 성향이나 능력" 
                                    },
                                    "Effect_Type": { 
                                        "type": "string", 
                                        "enum": ["NONE", "SETTING_CHANGE", "WORLD_CHANGE"],
                                        "description": "이 사건이 기존 설정을 바꾸는 터닝 포인트인지 여부" 
                                    },
                                    "State_Update": {
                                        "type": ["object", "null"],
                                        "description": "Effect_Type이 SETTING_CHANGE일 경우, 변경할 상태의 상세 정보 (기획서의 동적 변경 로직 적용)",
                                        "properties": {
                                        "Target_Char_ID": { "type": "string" },
                                        "Target_Trait": { "type": "string", "description": "변경될 특성 (예: Trauma_ID)" },
                                        "New_Value": { "type": "string", "description": "새롭게 덮어씌울 값 (예: Resolved)" }
                                        }
                                    }
                                }
                            },
                            "Memo": { 
                                "type": "string", 
                                "description": "작가의 메모 또는 에이전트의 생성 의도 주석" 
                            }
                        }
                    }
                }
            }
        },

        /* 아이디어 스키마: 사용자가 떠올린 파편적인 아이디어(설정, 대사, 묘사 등)를 저장하고, 적재적소에 꺼내 쓰기 위한 데이터 스키마 */
        "type": "object",
        "properties": {
            "user_ideas": {
                "type": "array",
                "items": {
                    "type": "object",
                    "required": ["idea_id", "content", "idea_types", "status"],
                    "properties": {
                    "idea_id": {
                        "type": "string",
                        "pattern": "^IDEA_[0-9]{8}_[0-9]{3}$",
                        "description": "아이디어 고유 식별자 (예: IDEA_20260324_001)"
                    },
                    "content": {
                        "type": "string",
                        "description": "사용자가 입력한 구체적인 아이디어, 대사, 혹은 묘사 문장"
                    },
                    "idea_types": {
                        "type": "array",
                        "description": "이 아이디어가 해당하는 속성 (복수 선택 가능)",
                        "items": {
                        "type": "string","enum": [
                            "인물",          // Character : 성격, MBTI, 트라우마, 두 인물 간의 관계도 변화 등
                            "세계관/규칙",   // World/Rule : 마법 체계, 기술 수준, 시대상, 사회적 금기 등 (단순 장소를 넘어선 설정)
                            "장소/배경",     // Location: 특정 사건이 벌어지는 물리적인 공간이나 지리적 특징
                            "사건/플롯",     // Event/Plot : 반전, 갈등 상황, 문제 해결 방식 등 이야기의 흐름
                            "소재/아이템",   // Prop/Item : 마법의 수단(Magical agent), 중요한 단서, 특수 장비 등
                            "대사",         // Dialogue : 인물의 성격을 보여주는 찰진 대사나 독백
                            "묘사/문장",    // Description : 소설 집필 시 활용할 분위기 묘사나 수려한 텍스트 문장
                            "연출/시각",    // Directing/Visual : 웹툰 컷 분할, 카메라 구도, 조명, 인물의 특정 표정 등 시각적 아이디어
                            "주제/메시지",  // Theme : 작품을 관통하는 로그라인이나 철학적 메시지
                            "기타"          // ETC : 분류하기 애매한 떠오르는 영감
                            ]
                        },
                        "minItems": 1
                    },
                    "target_sections": {
                        "type": "array",
                        "description": "이 아이디어가 활용되기 가장 적합한 창작 단계",
                        "items": {
                        "type": "string",
                        "enum": [
                            "Section 01. 이야기 발상과 설정",
                            "Section 02. 플롯 구성",
                            "Section 03. 세계관 & 캐릭터 설계",
                            "Section 04. 블록별 장면 구체화",
                            "Section 05. 소설 집필 & 최종 원고 개발",
                            "ANY"
                        ]
                        }
                    },
                    "tags": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "빠른 검색을 위한 키워드 태그 (예: ['비오는날', '복수', '감성적'])"
                    },
                    "constraints": {
                        "type": "object",
                        "description": "이 아이디어를 서사에 오류 없이 적용하기 위해 충족되어야 하는 논리적 제약 사항",
                        "properties": {
                        "required_character_traits": {
                            "type": "array",
                            "items": { "type": "string" }
                        },
                        "required_backgrounds": {
                            "type": "array",
                            "items": { "type": "string" }
                        },
                        "logical_dependencies": {
                            "type": "array",
                            "items": { "type": "string" }
                        }
                        }
                    },
                    "status": {
                        "type": "string",
                        "enum": ["PENDING", "APPLIED", "DISCARDED"],
                        "description": "현재 아이디어의 반영 상태 (PENDING: 보류/대기중, APPLIED: 본편 서사에 적용됨, DISCARDED: 폐기됨)"
                    }
                    }
                }
            }
        }

    }
}
  
  
  
  